# =============================================================================
# SupportNaija — environment variables
# Copy this file to `.env.local` for local dev, or configure in your hosting
# provider (Vercel, Convex Dashboard, etc.) for production.
# =============================================================================

# -----------------------------------------------------------------------------
# Convex (https://convex.dev)
# -----------------------------------------------------------------------------
# Public Convex deployment URL — set automatically by `npx convex dev`.
# Format: https://<your-deployment>.convex.cloud
NEXT_PUBLIC_CONVEX_URL=https://your-deployment.convex.cloud

# Local-only: written by `npx convex dev` so the CLI knows which deployment
# to push functions to. Do NOT commit your real value.
CONVEX_DEPLOYMENT=

# -----------------------------------------------------------------------------
# Clerk auth (https://clerk.com)
# -----------------------------------------------------------------------------
# From the Clerk dashboard → API Keys.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxx
CLERK_SECRET_KEY=sk_test_xxx

# Optional: customize redirect URLs after sign-in / sign-up.
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# -----------------------------------------------------------------------------
# Paystack (https://paystack.com) — donation checkout + webhooks
# -----------------------------------------------------------------------------
# Public key used by the Paystack inline widget. Test keys start with pk_test_.
NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY=pk_test_xxx

# Server-side secret used to verify webhooks and call the Paystack API.
# Configure in your Convex deployment env (npx convex env set).
PAYSTACK_SECRET_KEY=sk_test_xxx

# Webhook signing secret — used to verify x-paystack-signature on inbound
# webhooks. Set in Convex env.
PAYSTACK_WEBHOOK_SECRET=

# -----------------------------------------------------------------------------
# Termii (https://termii.com) — airtime + SMS disbursements
# -----------------------------------------------------------------------------
# Server-side only. Configure in Convex env (npx convex env set).
TERMII_API_KEY=
TERMII_SENDER_ID=SupportNG

# -----------------------------------------------------------------------------
# BVN / NIN verification provider (provisional)
# -----------------------------------------------------------------------------
# Choose one: "dojah" | "monnify" | "mock". Use "mock" for local dev.
VERIFICATION_PROVIDER=mock
VERIFICATION_API_KEY=

# Salt used when hashing BVN/NIN values before storage. MUST be a long, random
# string and MUST be kept secret. Rotate carefully (re-hash impact!).
VERIFICATION_HASH_SALT=change-me-to-a-long-random-string

# -----------------------------------------------------------------------------
# Site
# -----------------------------------------------------------------------------
# Canonical site URL — used in metadata, OG images, sitemap, etc.
NEXT_PUBLIC_SITE_URL=https://supportnaija.com

# Comma-separated list of admin Clerk user IDs (for moderation actions).
ADMIN_CLERK_USER_IDS=
